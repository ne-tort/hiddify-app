{
  "log": {
    "level": "info"
  },
  "dns": {
    "servers": [
      {
        "type": "hosts",
        "tag": "dns-static"
      },
      {
        "type": "udp",
        "tag": "dns-remote",
        "detour": "select",
        "connect_timeout": "5s",
        "disable_tcp_keep_alive": true,
        "server": "8.8.8.8"
      },
      {
        "type": "https",
        "tag": "dns-remote-fallback",
        "detour": "select",
        "server": "8.8.8.8",
        "tls": {
          "enabled": true
        }
      },
      {
        "type": "https",
        "tag": "dns-trick-direct",
        "detour": "direct-fragment",
        "domain_resolver": {
          "server": "dns-direct",
          "strategy": "prefer_ipv4"
        },
        "server": "dns.cloudflare.com",
        "tls": {
          "enabled": true,
          "fragment": true,
          "fragment_fallback_delay": "300ms",
          "record_fragment": true
        }
      },
      {
        "type": "udp",
        "tag": "dns-direct",
        "connect_timeout": "5s",
        "disable_tcp_keep_alive": true,
        "server": "1.1.1.1"
      },
      {
        "type": "local",
        "tag": "dns-local",
        "prefer_go": true
      },
      {
        "type": "udp",
        "tag": "dns-remote-no-warp",
        "detour": "direct-fragment",
        "connect_timeout": "5s",
        "disable_tcp_keep_alive": true,
        "server": "8.8.8.8"
      }
    ],
    "rules": [
      {
        "domain": "api.cloudflareclient.com",
        "server": "dns-remote-no-warp",
        "strategy": "ipv4_only",
        "rewrite_ttl": 86400
      },
      {
        "domain": [
          "google.com",
          "api.cloudflareclient.com",
          "captive.apple.com",
          "cp.cloudflare.com"
        ],
        "server": "dns-direct",
        "strategy": "ipv4_only",
        "rewrite_ttl": 86400
      },
      {
        "server": "dns-remote",
        "strategy": "ipv4_only",
        "rewrite_ttl": 86400
      }
    ],
    "final": "dns-remote",
    "disable_expire": true,
    "independent_cache": true
  },
  "endpoints": [
    {
      "type": "wireguard",
      "tag": "wg-client",
      "mtu": 1280,
      "address": [
        "10.0.0.2/32"
      ],
      "private_key": "gM+xdS2D8G5ZAV9ZwCOJWyLoTt51pE405hAm5aSKumM=",
      "peers": [
        {
          "address": "itvzlet.ai-qwerty.ru",
