# Copy to .env and adjust. Used by run.py deploy and optional ssh/scp.

# Required for: python run.py deploy | cleanup (remote) | all
L3ROUTER_SERVER_HOST=your.vps.ip

# Optional: which file under configs/ to upload (default server.l3router.static.json).
# For SMB/Reality e2e use: hub.vps.synced.json
#L3ROUTER_SERVER_CONFIG=hub.vps.synced.json

# Optional
L3ROUTER_SERVER_USER=root
L3ROUTER_SERVER_CONFIG_PATH=/etc/sing-box/config.json
# systemd unit name (default sing-box). Ignored if L3ROUTER_REMOTE_RESTART_CMD is set.
L3ROUTER_SERVER_SERVICE=sing-box
# Hub in Docker: point CONFIG_PATH at the host bind-mount dir and restart the container, e.g.:
# L3ROUTER_SERVER_CONFIG_PATH=/root/wg-hub-stand/server-config-wg-hub/config.json
# L3ROUTER_REMOTE_RESTART_CMD=docker restart singbox-wg-hub-server
# If deploy --with-binary:
L3ROUTER_SERVER_BINARY_PATH=/usr/local/bin/sing-box
# Copy binary into a running container (scp to host, then docker cp + chmod inside):
#L3ROUTER_SERVER_DOCKER_CONTAINER=singbox-wg-hub-server
#L3ROUTER_SERVER_DOCKER_BINARY_TMP=/tmp/sing-box-linux-amd64
# Seconds to wait for container running before docker cp (default 120)
#L3ROUTER_DOCKER_WAIT_TIMEOUT=120

# go build tags (default matches AGENTS.md)
#L3ROUTER_GO_TAGS=with_gvisor,with_clash_api,with_utls,with_l3router

# e2e_smb_clients_100mb.sh: set 1 to force docker compose --build for SMB stack
#SMB_BUILD_IMAGE=0
