{
  "log": {
    "level": "warn"
  },
  "endpoints": [
    {
      "type": "masque",
      "tag": "masque-srv-default-paths",
      "mode": "server",
      "listen": "0.0.0.0",
      "listen_port": 18500,
      "certificate": "/etc/sing-box/cert.pem",
      "key": "/etc/sing-box/key.pem",
      "template_udp": "https://masque-server-core:18500/masque/udp/{target_host}/{target_port}",
      "template_ip": "https://masque-server-core:18500/masque/ip",
      "template_tcp": "https://masque-server-core:18500/masque/tcp/{target_host}/{target_port}"
    },
    {
      "type": "masque",
      "tag": "masque-srv-custom-prefix",
      "mode": "server",
      "listen": "0.0.0.0",
      "listen_port": 18501,
      "certificate": "/etc/sing-box/cert.pem",
      "key": "/etc/sing-box/key.pem",
      "template_udp": "https://masque-server-core:18501/m2/udp/{target_host}/{target_port}",
      "template_ip": "https://masque-server-core:18501/m2/ip",
      "template_tcp": "https://masque-server-core:18501/m2/tcp/{target_host}/{target_port}"
    },
    {
      "type": "masque",
      "tag": "masque-srv-scoped-connect-ip",
      "mode": "server",
      "listen": "0.0.0.0",
      "listen_port": 18502,
      "certificate": "/etc/sing-box/cert.pem",
      "key": "/etc/sing-box/key.pem",
      "allow_private_targets": true,
      "template_udp": "https://masque-server-core:18502/m3/udp/{target_host}/{target_port}",
      "template_ip": "https://masque-server-core:18502/m3/ip/{target}/{ipproto}",
      "template_tcp": "https://masque-server-core:18502/m3/tcp/{target_host}/{target_port}"
    },
    {
      "type": "masque",
      "tag": "masque-srv-auth-allowlist",
      "mode": "server",
      "listen": "0.0.0.0",
      "listen_port": 18503,
      "certificate": "/etc/sing-box/cert.pem",
      "key": "/etc/sing-box/key.pem",
      "server_token": "lab-multi-masque-token",
      "allowed_target_ports": [53, 80, 443, 853, 8080, 8443],
      "template_udp": "https://masque-server-core:18503/m4/udp/{target_host}/{target_port}",
      "template_ip": "https://masque-server-core:18503/m4/ip",
      "template_tcp": "https://masque-server-core:18503/m4/tcp/{target_host}/{target_port}"
    }
  ],
  "outbounds": [
    {
      "type": "direct",
      "tag": "direct"
    }
  ],
  "route": {
    "final": "direct"
  }
}
