        "detour": "select",
        "server": "8.8.8.8",
        "tls": {
          "enabled": true
        }
      },
      {
        "type": "https",
        "tag": "dns-trick-direct",
        "detour": "direct-fragment §hide§",
        "domain_resolver": {
          "server": "dns-direct",
          "strategy": "prefer_ipv4"
        },
        "server": "dns.cloudflare.com",
        "tls": {
          "enabled": true,
          "fragment": true,
          "fragment_fallback_delay": "300ms",
          "record_fragment": true
        }
      },
      {
        "type": "udp",
        "tag": "dns-direct",
        "connect_timeout": "5s",
        "disable_tcp_keep_alive": true,
        "server": "1.1.1.1"
      },
      {
        "type": "local",
        "tag": "dns-local",
        "prefer_go": true
      },
      {
        "type": "udp",
        "tag": "dns-remote-no-warp",
        "detour": "direct-fragment §hide§",
        "connect_timeout": "5s",
        "disable_tcp_keep_alive": true,
        "server": "8.8.8.8"
      },
      {
        "type": "fakeip",
        "tag": "dns-fake",
        "inet4_range": "198.18.0.0/15",
        "inet6_range": "fc00::/18"
      }
    ],
    "rules": [
      {
        "domain": "api.cloudflareclient.com",
        "server": "dns-remote-no-warp",
        "strategy": "ipv4_only",
        "rewrite_ttl": 86400
      },
      {
        "domain": [
          "api.cloudflareclient.com",
          "captive.apple.com",
          "cp.cloudflare.com",
          "google.com"
        ],
        "server": "dns-direct",
        "strategy": "ipv4_only",
        "rewrite_ttl": 86400
      },
      {
        "query_type": [
          "A",
          "AAAA"
        ],
        "server": "dns-fake",
        "strategy": "ipv4_only",
        "disable_cache": true,
        "rewrite_ttl": 86400
      },
      {
        "server": "dns-remote",
        "strategy": "ipv4_only",
        "rewrite_ttl": 86400
      }
    ],
    "final": "dns-remote",
    "disable_expire": true,
    "independent_cache": true
  },
  "inbounds": [
    {
      "type": "tun",
      "tag": "tun-in",
      "mtu": 9000,
