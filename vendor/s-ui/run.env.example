# Скопируйте в run.env (не коммитить) или экспортируйте переменные перед `python run.py`.
# Корень репозитория hiddify-app вычисляется автоматически из расположения vendor/s-ui/run.py.

# Обязательно для deploy/sync/up/certbot/verify:
SUI_RUN_HOST=31.56.211.60
SUI_RUN_USER=root

# Каталог на VPS: внутри должны появиться vendor/s-ui и hiddify-core/hiddify-sing-box (как в локальном клоне).
SUI_RUN_REMOTE_ROOT=/opt/hiddify-app
# Если раньше использовали только /opt/s-ui/{db,cert}, перенесите db в $SUI_RUN_REMOTE_ROOT/vendor/s-ui/db перед первым up.

# Compose-файл стенда (относительно vendor/s-ui на сервере).
SUI_RUN_COMPOSE_FILE=docker-compose.stand.yml

# Домен и порт для `run.py verify` (HTTPS панели).
SUI_RUN_VERIFY_DOMAIN=work.ai-qwerty.ru
SUI_RUN_VERIFY_PORT=2095

# Первичная выдача Let's Encrypt (run.py certbot):
SUI_RUN_CERTBOT_DOMAIN=work.ai-qwerty.ru
SUI_RUN_CERTBOT_EMAIL=netort@internet.ru

# Если rsync нет в PATH, используется tar|ssh (см. run.py).

# Деплой: образ собирается локально (кэш Docker/Go), на VPS передаётся готовый образ
# (docker save | ssh docker load), затем compose up --no-build — без долгой сборки на сервере.
# Перед загрузкой образа по умолчанию выполняется `docker compose down` на VPS; после up —
# `docker image prune -f` (старые слои с тем же тегом). Отключить: =0
# SUI_RUN_DEPLOY_DOWN_FIRST=1
# SUI_RUN_DEPLOY_IMAGE_PRUNE=1
#   python run.py deploy
# Редеплой только бинарника в уже запущенный контейнер:
#   python run.py redeploy-binary
# Отладочная полная сборка на VPS (долго):
#   python run.py remote-build
