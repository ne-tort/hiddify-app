# Copy to deploy.env (gitignored) or export before deploy_sui.py.
# Paths match vendor/s-ui/s-ui.service by default (systemd install).

# Основной VPS s-ui: 193.233.216.26 (см. vendor/s-ui/run.env.example)
SUI_DEPLOY_HOST=193.233.216.26
SUI_DEPLOY_USER=root

# Local binary to upload (after: cd .. && go build -o sui -tags "..." .)
SUI_DEPLOY_LOCAL_BINARY=../sui

# Remote (systemd layout from README / install.sh)
SUI_DEPLOY_REMOTE_BINARY=/usr/local/s-ui/sui
SUI_DEPLOY_SYSTEMD_UNIT=s-ui

# Optional: skip systemctl restart (1/true)
#SUI_DEPLOY_SKIP_RESTART=0

# Optional: custom restart instead of systemctl, e.g. docker:
#SUI_DEPLOY_RESTART_CMD=docker restart s-ui-local

# Docker binary deploy (like l3router deploy_server_binary): set container name, then script uses docker stop/cp/start
#SUI_DEPLOY_DOCKER_CONTAINER=s-ui-local
#SUI_DEPLOY_DOCKER_BINARY_TMP=/tmp/sui.upload
#SUI_DEPLOY_DOCKER_BINARY_IN_CONTAINER=/app/sui
#SUI_DEPLOY_DOCKER_WAIT_TIMEOUT=120

# Runtime ports inside process (optional; see README-deploy.md). Exported on server via systemd Environment= or docker -e.
#SUI_WEB_PORT=2095
#SUI_SUB_PORT=2096
