{
  "host": "your.vps.ip",
  "user": "root",
  "local_binary": "../sui",
  "remote_binary": "/usr/local/s-ui/sui",
  "systemd_unit": "s-ui",
  "skip_restart": false,
  "restart_cmd": "",
  "docker": {
    "container": "",
    "host_tmp": "/tmp/sui.upload",
    "path_in_container": "/app/sui",
    "wait_timeout_sec": 120
  },
  "publish_ports": {
    "web": 2095,
    "sub": 2096,
    "comment": "For docker-compose -p mapping documentation only; app ports are in DB or SUI_WEB_PORT/SUI_SUB_PORT"
  }
}
