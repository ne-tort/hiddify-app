{
  "log": {
    "level": "warn"
  },
  "endpoints": [
    {
      "type": "masque",
      "tag": "masque-server",
      "mode": "server",
      "listen": "0.0.0.0",
      "listen_port": 8443,
      "template_udp": "https://masque-server-core:8443/masque/udp/{target_host}/{target_port}",
      "template_ip": "https://masque-server-core:8443/masque/ip",
      "template_tcp": "https://masque-server-core:8443/masque/tcp/{target_host}/{target_port}",
      "allow_private_targets": true,
      "tls": {
        "enabled": true,
        "certificate_path": "/etc/sing-box/cert.pem",
        "key_path": "/etc/sing-box/key.pem"
      }
    }
  ],
  "outbounds": [
    {
      "type": "direct",
      "tag": "direct"
    }
  ],
  "route": {
    "final": "direct"
  }
}
