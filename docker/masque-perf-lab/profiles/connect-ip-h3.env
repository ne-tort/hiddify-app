MASQUE_CONFIG_SOURCE=hiddify
MASQUE_HIDDIFY_CONFIG_PATH=docker\masque-perf-lab\configs\bench-client-source.json
MASQUE_TRANSPORT_MODE=connect_ip
MASQUE_HTTP_LAYER=h3
MASQUE_HTTP_LAYER_FALLBACK=false
MASQUE_TCP_TRANSPORT=connect_ip
MASQUE_TEMPLATE_IP=/masque/ip
MASQUE_TEMPLATE_TCP=/masque/tcp/{target_host}/{target_port}
MASQUE_TUN_STACK=gvisor
BENCH_TUN_WARMUP_SEC=25
BENCH_CONNECT_IP_WARMUP_SEC=60
