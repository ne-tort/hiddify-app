# Скопируйте в remote.credentials.env (файл в .gitignore) для своего VPS.
# Тестовый стенд §15.1a: креды уже в remote.stand.env (server_token = bearer_tokens[0] на сервере).
# Запуск Remote: powershell -NoProfile -File scripts/Run-MasquePerfLab.ps1 -Mode Remote

MASQUE_SERVER=193.233.216.26
MASQUE_SERVER_PORT=4438
MASQUE_SERVER_TOKEN=YOUR_SERVER_TOKEN
MASQUE_BASIC_USERNAME=YOUR_BASIC_USER
MASQUE_BASIC_PASSWORD=YOUR_BASIC_PASSWORD

# TLS к публичному имени (часто = домен панели); при insecure всё равно задаётся SNI.
MASQUE_TLS_SERVER_NAME=

# connect_udp | connect_ip | auto — как в sing-box
MASQUE_TRANSPORT_MODE=connect_udp

# h3 | h2 | auto | пусто = поле http_layer не писать (дефолт sing-box)
MASQUE_HTTP_LAYER=

# connect_stream | connect_ip | auto
MASQUE_TCP_TRANSPORT=connect_stream

# strict | direct_explicit
MASQUE_FALLBACK_POLICY=strict

# strict_masque | masque_or_direct
MASQUE_TCP_MODE=strict_masque

# Шаблоны (путь относительный — sing-box допишет https://server:port)
MASQUE_TEMPLATE_UDP=/masque/udp/{target_host}/{target_port}
MASQUE_TEMPLATE_TCP=/masque/tcp/{target_host}/{target_port}

# iperf через туннель (трафик: ваш клиент → MASQUE на VPS → этот хост:порт)
BENCH_IPERF_TARGET_HOST=iperf.he.net
BENCH_IPERF_TARGET_PORT=5200

# Доп. аргументы iperf3 (например -R reverse)
IPERF_ARGS=-t 30 -P 2

# curl | iperf — см. remote.stand.env и AGENTS.md §15.1a
BENCH_MODE=curl
CURL_BENCH_URL=https://speed.cloudflare.com/__down?bytes=80000000
